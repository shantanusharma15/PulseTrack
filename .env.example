# PulseTrack Environment Configuration
# Copy this file to .env and fill in your values
# Usage: source .env before running scripts

# Optional: GitHub Personal Access Token
# Without token: 60 requests/hr (enough for dev)
# With token:   5000 requests/hr (recommended)
# Get one at: https://github.com/settings/tokens (no scopes needed)
GITHUB_TOKEN=

# Languages to track (comma-separated, no spaces)
PULSETRACK_LANGUAGES=python,javascript,go,rust,java

# How many days back to search for new repos
PULSETRACK_DAYS_BACK=7

# How many repos per language per run
PULSETRACK_PER_PAGE=50

# DuckDB file location (relative to project root)
PULSETRACK_DB_PATH=data/pulsetrack.duckdb
